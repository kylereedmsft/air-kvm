{
  "manifest_version": 3,
  "name": "AirKVM Bridge",
  "version": "0.1.0",
  "description": "POC bridge for DOM state and screenshot transfer to AirKVM controller.",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "desktopCapture", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "AirKVM Bridge"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
